import numpy as np
from scipy.io.wavfile import write, read
import sounddevice as sd
import itertools
import tkinter as tk
from tkinter import messagebox
import matplotlib.pyplot as plt

class DTMFApp:
    def __init__(self, root):
        self.root = root
        self.root.title("DTMF Text Encoder & Decoder")
        self.root.geometry("500x450")

        # Karakter ve Frekans Tanımlamaları
        self.characters = [
            "A","B","C","Ç","D","E","F","G","Ğ","H",
            "I","İ","J","K","L","M","N","O","Ö","P",
            "R","S","Ş","T","U","Ü","V","Y","Z"," "
        ]
        self.low_freqs = [600, 700, 800, 900, 1000, 1100]
        self.high_freqs = [1200, 1300, 1400, 1500, 1600]
        self.freq_pairs = list(itertools.product(self.low_freqs, self.high_freqs))

        self.char_freq_map = {char: self.freq_pairs[i] for i, char in enumerate(self.characters)}
        self.reverse_map = {v: k for k, v in self.char_freq_map.items()}

        self.fs = 8000
        self.duration = 0.04  # 40 ms
        self.samples_per_char = int(self.fs * self.duration)
        self.filename = "output.wav"

        self.setup_ui()

    def setup_ui(self):
        tk.Label(self.root, text="DTMF Encoding & Decoding System", font=("Arial", 14, "bold")).pack(pady=10)
        
        self.entry = tk.Entry(self.root, width=40, font=("Arial", 12))
        self.entry.pack(pady=10)

        # Butonlar
        btn_frame = tk.Frame(self.root)
        btn_frame.pack(pady=10)

        tk.Button(btn_frame, text="1. Encode (Sentezle)", command=self.encode_text, width=20, bg="#d9ead3").grid(row=0, column=0, padx=5, pady=5)
        tk.Button(btn_frame, text="2. Decode (FFT)", command=self.decode_fft, width=20, bg="#cfe2f3").grid(row=1, column=0, padx=5, pady=5)
        tk.Button(btn_frame, text="2. Decode (Goertzel)", command=self.decode_goertzel, width=20, bg="#cfe2f3").grid(row=2, column=0, padx=5, pady=5)
        
        tk.Button(btn_frame, text="Grafik: Spektrum", command=self.show_spectrum, width=20, bg="#fff2cc").grid(row=1, column=1, padx=5, pady=5)
        tk.Button(btn_frame, text="Grafik: Zaman Düzeyi", command=self.show_waveform, width=20, bg="#fff2cc").grid(row=2, column=1, padx=5, pady=5)

        self.result_label = tk.Label(self.root, text="Sonuç bekleniyor...", font=("Arial", 12), fg="blue")
        self.result_label.pack(pady=20)

    def format_turkish_text(self, text):
        """Türkçe 'i' ve 'ı' harflerini upper() metodunun bozmasını engeller."""
        return text.replace('i', 'İ').replace('ı', 'I').upper()

    def generate_tone(self, f1, f2):
        t = np.linspace(0, self.duration, self.samples_per_char, endpoint=False)
        return np.sin(2 * np.pi * f1 * t) + np.sin(2 * np.pi * f2 * t)

    def encode_text(self):
        text = self.format_turkish_text(self.entry.get())
        if not text:
            messagebox.showwarning("Uyarı", "Lütfen bir metin girin.")
            return

        final_signal = np.array([])
        for char in text:
            if char in self.char_freq_map:
                f1, f2 = self.char_freq_map[char]
                tone = self.generate_tone(f1, f2)
                final_signal = np.concatenate((final_signal, tone))
            else:
                messagebox.showerror("Hata", f"Desteklenmeyen karakter: {char}")
                return

        # Sinyali normalize et (Clipping'i önlemek için)
        final_signal = final_signal / np.max(np.abs(final_signal))

        # Dosyaya kaydet ve çal (sd.wait() kaldırıldı, arayüz donmayacak)
        write(self.filename, self.fs, final_signal.astype(np.float32))
        sd.play(final_signal, self.fs)
        
        messagebox.showinfo("Başarılı", "Metin sese dönüştürüldü ve output.wav olarak kaydedildi.")

    def load_signal(self):
        """Ses dosyasını güvenli bir şekilde yükler, hata varsa uyarı verir."""
        try:
            fs_read, signal = read(self.filename)
            if len(signal.shape) > 1:
                signal = signal[:, 0]  # Stereo ise monoya çevir
            return fs_read, signal
        except FileNotFoundError:
            messagebox.showerror("Hata", "Önce bir ses dosyası (Encode) oluşturmalısınız.")
            return None, None

    def decode_fft(self):
        fs_read, signal = self.load_signal()
        if signal is None: return

        decoded_text = ""
        # Eşik değeri: Maksimum genliğin %5'i altındaki sesleri (gürültü/sessizlik) yoksay
        threshold = np.max(np.abs(signal)) * 0.05 

        for i in range(0, len(signal), self.samples_per_char):
            segment = signal[i:i + self.samples_per_char]
            if len(segment) < self.samples_per_char:
                continue
            
            # Sessizlik kontrolü
            if np.max(np.abs(segment)) < threshold:
                continue

            # Hamming pencereleme spektral sızıntıyı önler
            segment = segment * np.hamming(len(segment))
            spectrum = np.abs(np.fft.fft(segment))
            freqs = np.fft.fftfreq(len(segment), 1/fs_read)

            positive_freqs = freqs[:len(freqs)//2]
            positive_spectrum = spectrum[:len(spectrum)//2]

            peak_indices = positive_spectrum.argsort()[-2:]
            detected_freqs = sorted([int(abs(positive_freqs[idx])) for idx in peak_indices])

            closest_pair = None
            min_error = float('inf')

            for pair in self.reverse_map.keys():
                error = abs(pair[0] - detected_freqs[0]) + abs(pair[1] - detected_freqs[1])
                if error < min_error and error < 100: # Maksimum hata payı
                    min_error = error
                    closest_pair = pair

            if closest_pair:
                decoded_text += self.reverse_map[closest_pair]

        self.update_result(decoded_text, "FFT")

    def goertzel(self, segment, target_freq, fs):
        N = len(segment)
        k = int(0.5 + (N * target_freq) / fs)
        omega = (2.0 * np.pi * k) / N
        coeff = 2.0 * np.cos(omega)

        s_prev = 0
        s_prev2 = 0
        for sample in segment:
            s = sample + coeff * s_prev - s_prev2
            s_prev2 = s_prev
            s_prev = s

        return s_prev2**2 + s_prev**2 - coeff * s_prev * s_prev2

    def decode_goertzel(self):
        fs_read, signal = self.load_signal()
        if signal is None: return

        decoded_text = ""
        threshold = np.max(np.abs(signal)) * 0.05

        for i in range(0, len(signal), self.samples_per_char):
            segment = signal[i:i + self.samples_per_char]
            if len(segment) < self.samples_per_char:
                continue

            if np.max(np.abs(segment)) < threshold:
                continue

            # Hamming pencereleme
            segment = segment * np.hamming(len(segment))

            max_power = 0
            detected_pair = None

            for pair in self.char_freq_map.values():
                power1 = self.goertzel(segment, pair[0], fs_read)
                power2 = self.goertzel(segment, pair[1], fs_read)
                total_power = power1 + power2

                if total_power > max_power:
                    max_power = total_power
                    detected_pair = pair

            if detected_pair:
                decoded_text += self.reverse_map[detected_pair]

        self.update_result(decoded_text, "Goertzel")

    def update_result(self, decoded_text, method):
        original_text = self.format_turkish_text(self.entry.get())
        if original_text:
            min_len = min(len(original_text), len(decoded_text))
            correct = sum(1 for a, b in zip(original_text[:min_len], decoded_text[:min_len]) if a == b)
            accuracy = (correct / max(len(original_text), 1)) * 100
            self.result_label.config(text=f"[{method}] Çözülen: {decoded_text} | Başarı: %{accuracy:.1f}")
        else:
            self.result_label.config(text=f"[{method}] Çözülen: {decoded_text}")

    def show_spectrum(self):
        fs_read, signal = self.load_signal()
        if signal is None: return

        segment = signal[:self.samples_per_char]
        segment = segment * np.hamming(len(segment))
        spectrum = np.abs(np.fft.fft(segment))
        freqs = np.fft.fftfreq(len(segment), 1/fs_read)

        positive_freqs = freqs[:len(freqs)//2]
        positive_spectrum = spectrum[:len(spectrum)//2]

        plt.figure("Frekans Spektrumu")
        plt.plot(positive_freqs, positive_spectrum, color='blue')
        plt.title("Frekans Spektrumu (İlk Karakter)")
        plt.xlabel("Frekans (Hz)")
        plt.ylabel("Genlik (Magnitude)")
        plt.grid(True)
        plt.show()

    def show_waveform(self):
        fs_read, signal = self.load_signal()
        if signal is None: return

        # Ekranda çok sıkışık görünmemesi için sadece ilk 1-2 karakterin süresini gösterelim
        display_samples = min(len(signal), self.samples_per_char * 2) 
        
        plt.figure("Zaman Düzeyi")
        plt.plot(np.arange(display_samples) / fs_read, signal[:display_samples], color='red')
        plt.title("Zaman Düzeyindeki Sinyal (İlk Karakterler)")
        plt.xlabel("Zaman (saniye)")
        plt.ylabel("Genlik")
        plt.grid(True)
        plt.show()

if __name__ == "__main__":
    root = tk.Tk()
    app = DTMFApp(root)
    root.mainloop()